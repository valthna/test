# Vercel AI Gateway — required for the app's real LLM intelligence.
# Create a key in your Vercel project: AI Gateway tab -> API Keys.
# Set these in Vercel: Project -> Settings -> Environment Variables.
AI_GATEWAY_API_KEY=

# Optional: model routed through the gateway (creator/model slug).
# Examples: openai/gpt-4o-mini (default), anthropic/claude-3.5-haiku, google/gemini-2.0-flash
AI_GATEWAY_MODEL=openai/gpt-4o-mini
