# Vercel AI Gateway — required for the app's real LLM intelligence.
# Create a key in your Vercel project: AI Gateway tab -> API Keys.
# Set these in Vercel: Project -> Settings -> Environment Variables.
AI_GATEWAY_API_KEY=

# Optional: pin a model (creator/model slug) at the front of the candidate list.
# If unset, the app tries anthropic/claude-sonnet-4 -> claude-3.7-sonnet ->
# claude-3.5-sonnet -> openai/gpt-4o -> openai/gpt-4o-mini and uses the first
# one the gateway accepts. Examples: anthropic/claude-3.5-sonnet, openai/gpt-4o
AI_GATEWAY_MODEL=
